---
interface Props {
  title: string;
  date: Date;
  location: string;
  type: string;
  description: string;
  href?: string;
}

const { title, date, location, type, description, href } = Astro.props;
const formatted = date.toLocaleDateString('en', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
---

<article class="event-row">
  <div class="date-block">
    <span>{formatted.split(' ')[0]}</span>
    <strong>{date.getUTCDate()}</strong>
  </div>
  <div>
    <p class="meta">{type} · {location}</p>
    <h3>{href ? <a href={href}>{title}</a> : title}</h3>
    <p>{description}</p>
  </div>
</article>

<style>
  .event-row {
    display: grid;
    grid-template-columns: 76px 1fr;
    gap: 1rem;
    border-top: 1px solid var(--line);
    padding: 1.15rem 0;
  }

  .date-block {
    display: grid;
    height: 76px;
    place-items: center;
    border-radius: 8px;
    background: #13202a;
    color: #dff9ff;
  }

  .date-block span {
    align-self: end;
    color: #93dfea;
    font-size: 0.75rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  .date-block strong {
    align-self: start;
    font-size: 1.8rem;
    line-height: 1.1;
  }

  h3,
  p {
    margin: 0;
  }

  h3 {
    margin-top: 0.2rem;
    font-size: 1.15rem;
  }

  .meta {
    color: var(--signal);
    font-size: 0.82rem;
    font-weight: 850;
  }

  p:not(.meta) {
    color: var(--muted);
    line-height: 1.55;
    margin-top: 0.35rem;
  }
</style>
