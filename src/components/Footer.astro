---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-grid">
    <div>
      <div class="footer-logo-wrap">
        <img class="footer-logo" src="/images/tcrl-logo.svg" alt="IEEE Robotics and Automation Society Technical Committee on Robot Learning" />
      </div>
      <p class="eyebrow">IEEE RAS Technical Committee</p>
      <h2>Robot Learning</h2>
      <p>
        Community infrastructure for learning-enabled robotics: events, resources,
        mentoring, and coordination across research areas.
      </p>
    </div>
    <div class="footer-links">
      <a href="/join/">Contact</a>
      <a href="/resources/">Resources</a>
      <a href="/news/">News</a>
      <a href="https://www.ieee-ras.org/" rel="noreferrer">IEEE RAS</a>
    </div>
  </div>
  <div class="container footer-bottom">
    <span>© {year} IEEE RAS Technical Committee on Robot Learning.</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    background: #0f151c;
    color: #eef5f8;
    padding: 4rem 0 1.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
  }

  h2 {
    margin: 0.5rem 0 0.75rem;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1;
  }

  .footer-logo-wrap {
    display: grid;
    width: min(520px, 100%);
    min-height: 210px;
    place-items: center;
    border-radius: 8px;
    background: #fff;
    padding: 1rem;
    margin-bottom: 1.4rem;
  }

  .footer-logo {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  p {
    max-width: 560px;
    color: #aebbc7;
    line-height: 1.7;
  }

  .footer-links {
    display: grid;
    align-content: start;
    gap: 0.72rem;
    min-width: 180px;
    font-weight: 780;
  }

  .footer-links a {
    color: #dceff5;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    margin-top: 3rem;
    padding-top: 1rem;
    color: #93a2af;
    font-size: 0.86rem;
  }

  @media (max-width: 720px) {
    .footer-grid,
    .footer-bottom {
      display: grid;
    }
  }
</style>
