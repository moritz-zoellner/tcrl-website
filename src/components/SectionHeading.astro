---
interface Props {
  eyebrow: string;
  title: string;
  copy?: string;
}

const { eyebrow, title, copy } = Astro.props;
---

<div class="section-heading">
  <p class="eyebrow">{eyebrow}</p>
  <h2 class="section-title">{title}</h2>
  {copy && <p class="section-copy">{copy}</p>}
</div>

<style>
  .section-heading {
    display: grid;
    gap: 0.7rem;
  }

  h2,
  p {
    margin: 0;
  }
</style>
