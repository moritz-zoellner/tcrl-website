---
import { Menu } from '@lucide/astro';

const nav = [
  { href: '/activities/', label: 'Activities' },
  { href: '/news/', label: 'News' },
  { href: '/resources/', label: 'Resources' },
  { href: '/people/', label: 'People' },
  { href: '/join/', label: 'Join' },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="IEEE RAS TC on Robot Learning home">
      <span class="brand-mark scale-150 mr-5" aria-hidden="true">
        <img src="/images/tcrl-logo.svg" alt="" class="ml-3 scale-[135%]"/>
      </span>
      <span>
        <strong>Robot Learning</strong>
        <small>IEEE RAS Technical Committee</small>
      </span>
    </a>
    <nav class="nav" aria-label="Main navigation">
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <details class="mobile-nav">
      <summary aria-label="Open navigation">
        <Menu size={20} />
      </summary>
      <div class="mobile-menu">
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
      </div>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid rgba(16, 20, 24, 0.1);
    background: rgba(251, 252, 253, 0.86);
    backdrop-filter: blur(18px);
  }

  .header-inner {
    display: grid;
    min-height: 72px;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    width: fit-content;
  }

  .brand-mark {
    display: grid;
    width: 74px;
    height: 46px;
    place-items: center;
    border: 1px solid rgba(111, 26, 122, 0.24);
    border-radius: 8px;
    background: #fff;
    overflow: visible;
  }

  .brand-mark img {
    width: 66px;
    height: 40px;
    object-fit: contain;
  }

  .brand strong,
  .brand small {
    display: block;
  }

  .brand strong {
    font-size: 0.98rem;
  }

  .brand small {
    color: var(--muted);
    font-size: 0.76rem;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.15rem;
    color: #26323c;
    font-size: 0.91rem;
    font-weight: 760;
  }

  .nav a {
    border-bottom: 2px solid transparent;
    padding-block: 0.4rem;
  }

  .nav a:hover {
    border-color: var(--accent);
  }

  .mobile-nav {
    position: relative;
    display: none;
  }

  .mobile-nav summary {
    display: none;
    width: 42px;
    height: 42px;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: white;
    color: var(--ink);
    cursor: pointer;
    list-style: none;
  }

  .mobile-nav summary::-webkit-details-marker {
    display: none;
  }

  .mobile-menu {
    position: absolute;
    right: 0;
    top: calc(100% + 0.65rem);
    display: grid;
    width: min(260px, calc(100vw - 28px));
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    padding: 0.55rem;
    box-shadow: 0 18px 44px rgba(16, 20, 24, 0.18);
  }

  .mobile-menu a {
    border-radius: 6px;
    color: #22303a;
    font-weight: 800;
    padding: 0.8rem;
  }

  .mobile-menu a:hover {
    background: var(--panel);
  }

  @media (max-width: 860px) {
    .header-inner {
      grid-template-columns: 1fr auto;
    }

    .nav {
      display: none;
    }

    .mobile-nav {
      display: block;
    }

    .mobile-nav summary {
      display: grid;
    }
  }
</style>
