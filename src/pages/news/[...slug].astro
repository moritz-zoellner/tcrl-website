---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('news');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const formattedDate = post.data.date.toLocaleDateString('en', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="article">
    <div class="container article-inner">
      <a class="back" href="/news/">News</a>
      <p class="eyebrow">{formattedDate}</p>
      <h1>{post.data.title}</h1>
      <p class="dek">{post.data.description}</p>
      <div class="content">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    padding: 6rem 0;
  }

  .article-inner {
    max-width: 850px;
  }

  .back {
    display: inline-flex;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.5rem 0.75rem;
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 780;
    margin-bottom: 1.5rem;
  }

  h1 {
    margin: 0.7rem 0 1rem;
    font-size: clamp(2.7rem, 6vw, 5.4rem);
    line-height: 0.95;
  }

  .dek {
    color: var(--muted);
    font-size: 1.18rem;
    line-height: 1.65;
  }

  .content {
    border-top: 1px solid var(--line);
    margin-top: 2.2rem;
    padding-top: 2rem;
    color: #23303a;
    line-height: 1.75;
  }

  .content :global(h2) {
    margin-top: 2rem;
    font-size: 1.5rem;
  }

  .content :global(a) {
    color: var(--accent-strong);
    font-weight: 780;
    text-decoration: underline;
  }
</style>
