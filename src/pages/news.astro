---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';

const posts = (await getCollection('news')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const getSlug = (id: string) => id.replace(/\.(md|mdx)$/, '');
const formatDate = (date: Date) => date.toLocaleDateString('en', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
---

<BaseLayout title="News" description="News and updates from the IEEE RAS TC on Robot Learning.">
  <section class="page-intro">
    <div class="container">
      <SectionHeading
        eyebrow="News"
        title="Announcements and updates from the Robot Learning TC."
        copy="Follow committee news, calls for participation, workshop updates, resource releases, and community activity."
      />
    </div>
  </section>
  <section class="news-section">
    <div class="container news-grid">
      {posts.map((post) => (
        <a class="news-card card" href={`/news/${getSlug(post.id)}/`}>
          <span>{formatDate(post.data.date)}</span>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page-intro {
    padding: 6rem 0 3rem;
  }

  .news-section {
    padding: 1rem 0 6rem;
  }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .news-card {
    display: grid;
    gap: 0.7rem;
    min-height: 240px;
    padding: 1.1rem;
  }

  span {
    color: var(--accent-strong);
    font-size: 0.8rem;
    font-weight: 850;
  }

  h2,
  p {
    margin: 0;
  }

  h2 {
    font-size: 1.35rem;
    line-height: 1.14;
  }

  p {
    color: var(--muted);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .news-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .news-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
