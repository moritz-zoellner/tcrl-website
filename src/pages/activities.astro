---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EventRow from '../components/EventRow.astro';
import SectionHeading from '../components/SectionHeading.astro';

const events = (await getCollection('events')).sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

---

<BaseLayout title="Activities" description="Workshops, events, calls, and activities for the IEEE RAS TC on Robot Learning.">
  <section class="page-intro dark-panel mesh">
    <div class="container intro-grid">
      <SectionHeading
        eyebrow="Activities"
        title="Activities, events, and community coordination."
        copy="Follow workshops, conference activities, planning calls, mentoring efforts, and other TC initiatives connected to robot learning within IEEE RAS."
      />
    </div>
  </section>
  <section class="events-section">
    <div class="container">
      <h2>Upcoming Activities</h2>
      {events.map((event) => (
        <EventRow
          title={event.data.title}
          date={event.data.date}
          location={event.data.location}
          type={event.data.type}
          description={event.data.description}
          href={event.data.href}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page-intro {
    padding: 6rem 0;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr minmax(300px, 0.52fr);
    gap: 3rem;
    align-items: start;
  }

  .activity-card {
    display: grid;
    gap: 0.8rem;
  }

  .activity-card span {
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.06);
    color: #e7f4f8;
    font-weight: 780;
    padding: 1rem;
  }

  .events-section {
    padding: 5rem 0 6rem;
  }

  h2 {
    margin: 0 0 1rem;
    font-size: clamp(2rem, 4vw, 3rem);
  }

  @media (max-width: 860px) {
    .intro-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
